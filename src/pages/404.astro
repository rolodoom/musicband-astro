---
import Section from "@/components/shared/Section.astro";
import LayoutInnerPages from "../layouts/LayoutInnerPages.astro";
import Button from "@/components/ui/Button.astro";
import { Icon } from "astro-icon/components";
import sectionData from "@/data/error404.json";
import { t } from "@/i18n";

const { id, title, subtitle, description = "", config = {} } = sectionData;
---

<LayoutInnerPages title={title} description={description}>
  <Section {id} {title} {subtitle} {config}>
    {
      description !== "" && (
        <div
          class="mx-auto max-w-3xl pb-16 text-xl font-light"
          data-aos="fade-down"
        >
          {description}
        </div>
      )
    }
    <Button href="/"
      ><Icon name="fa7-solid:arrow-left" size={16} class="mr-1" />{
        t("goback")
      }</Button
    >
  </Section>
</LayoutInnerPages>
